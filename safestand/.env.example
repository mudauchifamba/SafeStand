# SafeStand — environment documentation (no runtime .env file is read).
# Secrets are injected at build time via --dart-define and are NEVER committed.
#
#   flutter run  --dart-define=GROQ_API_KEY=your_key_here
#   flutter build apk --dart-define=GROQ_API_KEY=your_key_here
#
# GROQ_API_KEY  Vision AI (satellite land-class + photo authenticity checks).
#               Optional: without it the app runs fully offline-featured and the
#               online AI sections show an honest "not configured" note.
GROQ_API_KEY=
